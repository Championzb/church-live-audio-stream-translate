{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Church Live Translate",
  "version": "0.2.0",
  "identifier": "com.church.live.translate",
  "build": {
    "beforeDevCommand": "npm run build:ui",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1500,
        "height": 920,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 14
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "mainBinaryName": "church-live-translate"
}
