{
  "name": "church-live-audio-stream-translate",
  "version": "0.2.0",
  "description": "Cross-platform live translation captions for church services",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "build:ui": "tsc -p tsconfig.json",
    "dev:ui": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tauri dev",
    "start": "tauri dev",
    "build": "tauri build",
    "build:mac": "tauri build --bundles app",
    "build:mac:dmg": "tauri build --bundles app,dmg",
    "build:win": "tauri build --target x86_64-pc-windows-msvc --bundles msi",
    "dist:collect": "node scripts/package-artifacts.mjs",
    "release:check:mac": "node scripts/check-signing-env.mjs mac",
    "release:check:win": "node scripts/check-signing-env.mjs win",
    "release:check:all": "node scripts/check-signing-env.mjs all",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm run test:unit",
    "test:coverage:gate": "c8 --check-coverage --lines 95 --branches 90 --functions 100 --statements 95 --reporter=text --reporter=lcov npm run test:unit",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.8.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
